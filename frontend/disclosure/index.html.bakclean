<script>
(function(){
  document.getElementById('year').textContent=new Date().getFullYear();
  try{var l=(localStorage.getItem('aplusz-lang')||navigator.language||'en').toLowerCase();if(l.indexOf('fr')===0){var a=document.getElementById('footer-disclosure');if(a)a.textContent='Divulgation';}}catch(e){}
  var bh=document.getElementById('brand-home');var fh=document.getElementById('footer-home');
  function goHome(e){var p=location.pathname.replace(/\/+$/,'');if(p===''||p==='/index.html'||p==='/index'){if(e)e.preventDefault();location.reload();}}
  if(bh)bh.addEventListener('click',goHome);if(fh)fh.addEventListener('click',goHome);
})();
</script></body>
