<script>
  // French users see French; everyone else sees English.
  (function () {
    function pickLang() {
      try { var s = localStorage.getItem('aplusz-lang'); if (s) return s.toLowerCase(); } catch (e) {}
      return (navigator.language || navigator.userLanguage || 'en').toLowerCase();
    }
    var isFR = pickLang().indexOf('fr') === 0;
    var en = document.getElementById('disc-en');
    var fr = document.getElementById('disc-fr');
    if (isFR) { en.hidden = true; fr.hidden = false; document.documentElement.lang = 'fr'; document.title = 'Divulgation � AplusZ'; }
    else { en.hidden = false; fr.hidden = true; document.documentElement.lang = 'en'; }
  })();
</script>

