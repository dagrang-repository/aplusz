<style>
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body {
    font-family: var(--font-sans);
    max-width: 720px;
    margin: 0 auto;
    padding: var(--sp-8) var(--sp-4) var(--sp-16);
    line-height: 1.6;
    color: var(--text);
    background: var(--bg);
    -webkit-font-smoothing: antialiased;
  }
  .back {
    display: inline-flex;
    align-items: center;
    gap: var(--sp-2);
    color: var(--link);
    text-decoration: none;
    font-size: var(--fs-sm);
    margin-bottom: var(--sp-6);
  }
  .back:hover { text-decoration: underline; }
  h1 { color: var(--accent); font-size: var(--fs-2xl); margin-bottom: var(--sp-4); letter-spacing: -0.02em; }
  h2 { color: var(--accent); font-size: var(--fs-xl); margin-top: var(--sp-8); margin-bottom: var(--sp-3); }
  h3 { color: var(--text); font-size: var(--fs-lg); margin-top: var(--sp-4); margin-bottom: var(--sp-2); }
  p, li { margin: var(--sp-2) 0; color: var(--text-muted); }
  ul { padding-left: var(--sp-6); }
  a { color: var(--link); }
  hr { border: 0; border-top: 1px solid var(--border); margin: var(--sp-8) 0; }
  strong { color: var(--text); }
  code { font-family: var(--font-mono); font-size: 0.9em; background: var(--surface); padding: 2px 6px; border-radius: var(--r-xs); }
</style>
