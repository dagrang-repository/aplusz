<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Offline · APlusZ</title>
<link rel="manifest" href="/apz.webmanifest">
<style>
  * { box-sizing: border-box; margin: 0; padding: 0; }
  html, body {
    height: 100%;
    font-family: var(--font-sans);
    background: var(--bg);
    color: var(--text);
    -webkit-font-smoothing: antialiased;
  }
  body {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: var(--sp-6);
  }
  .wrap {
    max-width: 420px;
    text-align: center;
    background: var(--bg-glass);
    backdrop-filter: blur(var(--glass-blur)) saturate(var(--glass-saturate));
    -webkit-backdrop-filter: blur(var(--glass-blur)) saturate(var(--glass-saturate));
    border: 1px solid var(--border);
    border-radius: var(--r-lg);
    padding: var(--sp-8);
    box-shadow: var(--shadow-lg);
  }
  .icon {
    font-size: 3rem;
    margin-bottom: var(--sp-4);
  }
  h1 {
    font-size: var(--fs-2xl);
    color: var(--accent);
    margin-bottom: var(--sp-3);
  }
  p {
    color: var(--text-muted);
    line-height: 1.6;
    margin-bottom: var(--sp-6);
  }
  button {
    background: var(--accent);
    color: var(--bg);
    border: none;
    padding: var(--sp-3) var(--sp-6);
    border-radius: var(--r-pill);
    font-size: var(--fs-base);
    font-weight: 600;
    cursor: pointer;
    transition: background var(--dur-base) var(--ease-spring);
  }
  button:hover { background: var(--accent-hover); }
  #cached-routes {
    margin-top: var(--sp-6);
    text-align: left;
  }
  #cached-routes:empty { display: none; }
  .route-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--r-md);
    padding: var(--sp-3);
    margin-bottom: var(--sp-2);
    font-size: var(--fs-sm);
  }
</style>
<link rel="stylesheet" href="/assets/bundle.css">
<script defer src="/assets/detect.js"></script>
<script defer src="/assets/config.js"></script>
<script defer src="/assets/i18n.js"></script>
<script defer src="/assets/billing.js"></script>
<script defer src="/assets/app.js"></script></head>
<body>
<header class="topbar">
  <a class="brand" id="brand-home" href="/" aria-label="AplusZ home">
    <span class="brand-mark">A+Z</span>
    <span class="brand-name"><span class="bn-az">A</span><span class="bn-plus">plus</span><span class="bn-az">Z</span><span class="bn-app">.app</span></span>
  </a>
  <nav class="topnav">
    <button class="icon-btn tier-badge" id="tier-badge" type="button" aria-label="Free"><span class="tb-ic">&#x1F193;</span><span class="tb-nm">Free</span></button>
    <button class="icon-btn" id="theme-toggle" aria-label="Theme">&#9728;</button>
    <button class="icon-btn" id="lang-btn" aria-label="Language">&#127760;</button>
    <button class="icon-btn" id="menu-btn" aria-label="Profile">&#9776;</button>
  </nav>
</header>

<div class="wrap">
  <div class="icon">✈️</div>
  <h1 data-i18n="offline.title">You're offline</h1>
  <p data-i18n="offline.message">Last cached results for your saved routes are below.</p>
  <button onclick="location.reload()">Retry</button>
  <div id="cached-routes"></div>
</div>

<script src="/assets/i18n.js"></script>
<script>
  // Load saved routes from localStorage if any
  try {
    var saved = JSON.parse(localStorage.getItem('aplusz-saved-routes') || '[]');
    var box = document.getElementById('cached-routes');
    saved.forEach(function (r) {
      var el = document.createElement('div');
      el.className = 'route-card';
      el.textContent = r.origin + ' → ' + r.destination + ' · ' + (r.lastPrice || '—');
      box.appendChild(el);
    });
  } catch (e) {}
</script>

<footer class="footer">
  <a href="/en/faq" data-i18n="nav.faq">FAQ</a>
  <span class="footer-sep"></span>
  <a href="/en/about" data-i18n="nav.about">About</a>
  <span class="footer-sep"></span>
  <a href="/en/feedback" data-i18n="nav.feedback">Feedback</a>
  <span class="footer-sep"></span>
  <a href="/legal/index.html" data-i18n="nav.legal">Legal</a>
  <span class="footer-sep"></span>
  <a href="/disclosure/index.html" id="footer-disclosure">Disclosure</a>
  <span class="footer-sep"></span>
  <span>&#169; <span id="year"></span> <a class="footer-brand" id="footer-home" href="/" aria-label="AplusZ home"><span class="bn-az">A</span><span class="bn-plus">plus</span><span class="bn-az">Z</span> <span class="footer-mark">(A+Z).app</span></a></span>
</footer>
<script>
(function(){
  document.getElementById('year').textContent=new Date().getFullYear();
  try{var l=(localStorage.getItem('aplusz-lang')||navigator.language||'en').toLowerCase();if(l.indexOf('fr')===0){var a=document.getElementById('footer-disclosure');if(a)a.textContent='Divulgation';}}catch(e){}
  var bh=document.getElementById('brand-home');var fh=document.getElementById('footer-home');
  function goHome(e){var p=location.pathname.replace(/\/+$/,'');if(p===''||p==='/index.html'||p==='/index'){if(e)e.preventDefault();location.reload();}}
  if(bh)bh.addEventListener('click',goHome);if(fh)fh.addEventListener('click',goHome);
})();
</script></body>
</html>
